# ScalperToday API - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - AI Analysis
# ===========================================
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===========================================
# REQUIRED - Economic Calendar Provider
# ===========================================
# forexfactory | rapidapi
EVENT_PROVIDER=forexfactory

# Free ForexFactory weekly JSON feed
FOREXFACTORY_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json

# RapidAPI Economic Calendar. Keep a high TTL with the free 30 requests/month plan.
RAPIDAPI_CALENDAR_KEY=your_rapidapi_key_here
RAPIDAPI_CALENDAR_HOST=economic-calendar-api.p.rapidapi.com
RAPIDAPI_CALENDAR_URL=https://economic-calendar-api.p.rapidapi.com/calendar
RAPIDAPI_CALENDAR_TIMEZONE=UTC
RAPIDAPI_CALENDAR_LIMIT=500
CALENDAR_CACHE_TTL_MINUTES=10080

# ===========================================
# REQUIRED - Authentication
# ===========================================
# Generate a secure random string (at least 32 characters)
# Example: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here

# Required for POST /api/v1/macro/refresh
REFRESH_API_KEY=your_refresh_api_key_here

# ===========================================
# OPTIONAL - Application Settings
# ===========================================
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# ===========================================
# OPTIONAL - Server
# ===========================================
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ===========================================
# OPTIONAL - Database
# ===========================================
DATABASE_PATH=data/scalper_today.db

# ===========================================
# OPTIONAL - AI Model
# ===========================================
OPENROUTER_MODEL=google/gemini-2.5-flash
HTTP_TIMEOUT_SECONDS=90

# ===========================================
# OPTIONAL - JWT Settings
# ===========================================
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRE_DAYS=30
